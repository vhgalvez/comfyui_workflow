{
  "workflow_name": "workflow_LTX_shorts_audio_sync_template",
  "purpose": "Plantilla limpia para crear shorts verticales con LTX 2.3 usando audio externo real y sincronización audio-video.",
  "notes": [
    "Esta plantilla es un blueprint técnico del workflow limpio recomendado para tu instalación y tus modelos.",
    "No es una exportación final de canvas lista para arrastrar, porque la serialización exacta de ComfyUI depende de la versión, IDs de nodos, extensiones instaladas y posiciones del canvas.",
    "La estructura, modelos, rutas y parámetros sí están alineados con tu instalación y con los nodos LTX de ComfyUI."
  ],
  "source_analysis": {
    "comfyui_installation_file": "ComfyUI.txt",
    "existing_workflow_file": "ltx-2.3-ts2v-yaskad.json"
  },
  "environment": {
    "platform": "Windows",
    "comfyui_base_path": "C:\\Users\\vhgal\\AppData\\Local\\Programs\\ComfyUI\\resources\\ComfyUI\\ComfyUI",
    "models_base_path": "C:\\Users\\vhgal\\AppData\\Local\\Programs\\ComfyUI\\resources\\ComfyUI\\ComfyUI\\models",
    "recommended_run_script": "C:\\Users\\vhgal\\AppData\\Local\\Programs\\ComfyUI\\resources\\ComfyUI\\ComfyUI\\.ci\\windows_nvidia_base_files\\run_nvidia_gpu.bat",
    "python_env_hint": "C:\\ProgramData\\anaconda3\\envs\\comfy\\python.exe",
    "target_gpu": "NVIDIA GeForce RTX 4070 12GB VRAM",
    "target_ram_gb": 32
  },
  "audio_source": {
    "original_audio_path": "C:\\Users\\vhgal\\Documents\\desarrollo\\ia\\AI-video-automation\\video-dataset\\jobs\\000010\\audio\\000010_narration.wav",
    "recommended_comfy_input_copy": "C:\\Users\\vhgal\\AppData\\Local\\Programs\\ComfyUI\\resources\\ComfyUI\\ComfyUI\\input\\000010_narration.wav",
    "loading_method": "LoadAudio"
  },
  "models": {
    "unet_gguf": {
      "recommended": "ltx-2-3-22b-dev-Q4_K_M.gguf",
      "alternative_higher_quality": "ltx-2-3-22b-dev-Q5_K_S.gguf",
      "path": "models\\unet\\ltx-2.3\\ltx-2-3-22b-dev-Q4_K_M.gguf"
    },
    "video_vae": {
      "filename": "LTX23_video_vae_bf16.safetensors",
      "path": "models\\vae\\ltx2.3\\LTX23_video_vae_bf16.safetensors"
    },
    "audio_vae": {
      "filename": "LTX23_audio_vae_bf16.safetensors",
      "path": "models\\vae\\ltx2.3\\LTX23_audio_vae_bf16.safetensors"
    },
    "text_encoder": {
      "filename": "gemma_3_12B_it_fp4_mixed.safetensors",
      "path": "models\\text_encoders\\gemma_3_12B_it_fp4_mixed.safetensors"
    },
    "text_projection": {
      "filename": "ltx-2.3_text_projection_bf16.safetensors",
      "path": "models\\text_encoders\\ltx-2.3_text_projection_bf16.safetensors"
    },
    "distilled_lora": {
      "filename": "ltx-2.3-22b-distilled-lora-dynamic_fro09_avg_rank_105_bf16.safetensors",
      "path": "models\\loras\\ltx2\\ltx-2.3-22b-distilled-lora-dynamic_fro09_avg_rank_105_bf16.safetensors",
      "strength_model": 0.6
    },
    "spatial_upscaler": {
      "filename": "ltx-2.3-spatial-upscaler-x2-1.0.safetensors",
      "path": "models\\latent_upscale_models\\ltx-2.3-spatial-upscaler-x2-1.0.safetensors"
    }
  },
  "shorts_defaults": {
    "orientation": "vertical",
    "target_aspect_ratio": "9:16",
    "fps": 24,
    "initial_length_frames": 97,
    "max_recommended_length_frames_on_4070": 121,
    "resize_longer_edge": 1536,
    "image_compression": 33,
    "tile_size": 512,
    "tile_overlap": 64,
    "temporal_size": 2048,
    "temporal_overlap": 8,
    "cfg": 1.0,
    "stage1_sampler": "euler",
    "stage2_sampler": "euler",
    "stage1_sigmas": "1., 0.99375, 0.9875, 0.98125, 0.975, 0.909375, 0.725, 0.421875, 0.0",
    "stage2_sigmas": "0.85, 0.7250, 0.4219, 0.0"
  },
  "prompt_template": {
    "positive": "Vertical short video, cinematic close-up portrait, strong lip sync to the provided narration, realistic facial motion, expressive eyes, subtle head movement, natural shoulders and torso motion, shallow depth of field, soft key light, background simple and clean, high detail skin, realistic mouth articulation, stable framing, short-form social media style, portrait orientation, professional short video, consistent identity, no subtitle burn-in.",
    "negative": "blurry, low quality, duplicated face, extra fingers, bad anatomy, subtitles, text overlay, watermark, heavy compression artifacts, flicker, jumpy camera, frozen face, bad lipsync, distorted mouth, deformed eyes"
  },
  "workflow_graph": {
    "section_A_input": [
      {
        "node": "LoadAudio",
        "params": {
          "audio_file": "000010_narration.wav"
        },
        "output": "AUDIO"
      },
      {
        "node": "LoadImage_or_EmptyImage",
        "params": {
          "mode": "use portrait base image if available, otherwise EmptyImage",
          "empty_width": 1080,
          "empty_height": 1920,
          "batch_size": 1,
          "color": 0
        },
        "output": "IMAGE"
      },
      {
        "node": "ResizeImagesByLongerEdge",
        "params": {
          "longer_edge": 1536
        },
        "output": "IMAGE"
      },
      {
        "node": "GetImageSize",
        "output": [
          "width",
          "height"
        ]
      },
      {
        "node": "LTXVPreprocess",
        "params": {
          "img_compression": 33
        },
        "output": "IMAGE"
      }
    ],
    "section_B_models": [
      {
        "node": "UnetLoaderGGUF",
        "params": {
          "unet_name": "ltx-2-3-22b-dev-Q4_K_M.gguf"
        },
        "output": "MODEL"
      },
      {
        "node": "LoraLoaderModelOnly",
        "params": {
          "lora_name": "ltx-2.3-22b-distilled-lora-dynamic_fro09_avg_rank_105_bf16.safetensors",
          "strength_model": 0.6
        },
        "output": "MODEL"
      },
      {
        "node": "DualCLIPLoader",
        "params": {
          "clip_name1": "gemma_3_12B_it_fp4_mixed.safetensors",
          "clip_name2": "ltx-2.3_text_projection_bf16.safetensors",
          "type": "ltxv",
          "device": "default"
        },
        "output": "CLIP"
      },
      {
        "node": "VAELoaderKJ_video",
        "params": {
          "vae_name": "LTX23_video_vae_bf16.safetensors",
          "device": "main_device",
          "weight_dtype": "bf16"
        },
        "output": "video_vae"
      },
      {
        "node": "VAELoaderKJ_audio_or_LTX_audio_loader",
        "params": {
          "vae_name": "LTX23_audio_vae_bf16.safetensors",
          "device": "main_device",
          "weight_dtype": "bf16"
        },
        "output": "audio_vae"
      }
    ],
    "section_C_audio_video_latents": [
      {
        "node": "LTXVAudioVAEEncode",
        "inputs": {
          "audio": "LoadAudio.AUDIO",
          "audio_vae": "audio_vae"
        },
        "output": "audio_latent"
      },
      {
        "node": "PrimitiveInt_Length",
        "params": {
          "value": 97
        },
        "output": "length"
      },
      {
        "node": "PrimitiveFloat_FPS",
        "params": {
          "value": 24.0
        },
        "output": "fps"
      },
      {
        "node": "EmptyLTXVLatentVideo",
        "inputs": {
          "width": "GetImageSize.width",
          "height": "GetImageSize.height",
          "length": "length"
        },
        "params": {
          "batch_size": 1
        },
        "output": "video_latent"
      },
      {
        "node": "LTXVConcatAVLatent",
        "inputs": {
          "video_latent": "video_latent",
          "audio_latent": "audio_latent"
        },
        "output": "av_latent_stage0"
      }
    ],
    "section_D_conditioning_and_stage1": [
      {
        "node": "CLIPTextEncode_positive",
        "params": {
          "text": "Vertical short video, cinematic close-up portrait, strong lip sync to the provided narration, realistic facial motion, expressive eyes, subtle head movement, natural shoulders and torso motion, shallow depth of field, soft key light, background simple and clean, high detail skin, realistic mouth articulation, stable framing, short-form social media style, portrait orientation, professional short video, consistent identity, no subtitle burn-in."
        },
        "output": "positive"
      },
      {
        "node": "CLIPTextEncode_negative",
        "params": {
          "text": "blurry, low quality, duplicated face, extra fingers, bad anatomy, subtitles, text overlay, watermark, heavy compression artifacts, flicker, jumpy camera, frozen face, bad lipsync, distorted mouth, deformed eyes"
        },
        "output": "negative"
      },
      {
        "node": "LTXVConditioning",
        "inputs": {
          "positive": "positive",
          "negative": "negative",
          "frame_rate": "fps"
        },
        "output": [
          "positive_ltx",
          "negative_ltx"
        ]
      },
      {
        "node": "CFGGuider",
        "params": {
          "cfg": 1.0
        },
        "output": "GUIDER"
      },
      {
        "node": "RandomNoise",
        "output": "NOISE"
      },
      {
        "node": "KSamplerSelect",
        "params": {
          "sampler_name": "euler"
        },
        "output": "SAMPLER"
      },
      {
        "node": "ManualSigmas",
        "params": {
          "sigmas": "1., 0.99375, 0.9875, 0.98125, 0.975, 0.909375, 0.725, 0.421875, 0.0"
        },
        "output": "SIGMAS"
      },
      {
        "node": "SamplerCustomAdvanced",
        "inputs": {
          "noise": "NOISE",
          "guider": "GUIDER",
          "sampler": "SAMPLER",
          "sigmas": "SIGMAS",
          "latent_image": "av_latent_stage0"
        },
        "output": "av_latent_stage1"
      }
    ],
    "section_E_refine_stage2": [
      {
        "node": "LTXVSeparateAVLatent",
        "inputs": {
          "av_latent": "av_latent_stage1"
        },
        "output": [
          "video_latent_stage1",
          "audio_latent_stage1"
        ]
      },
      {
        "node": "LatentUpscaleModelLoader",
        "params": {
          "model_name": "ltx-2.3-spatial-upscaler-x2-1.0.safetensors"
        },
        "output": "UPSCALE_MODEL"
      },
      {
        "node": "LTXVLatentUpsampler",
        "inputs": {
          "samples": "video_latent_stage1",
          "upscale_model": "UPSCALE_MODEL",
          "vae": "video_vae"
        },
        "output": "video_latent_upscaled"
      },
      {
        "node": "LTXVConcatAVLatent",
        "inputs": {
          "video_latent": "video_latent_upscaled",
          "audio_latent": "audio_latent_stage1"
        },
        "output": "av_latent_stage2_input"
      },
      {
        "node": "RandomNoise_stage2",
        "output": "NOISE"
      },
      {
        "node": "KSamplerSelect_stage2",
        "params": {
          "sampler_name": "euler"
        },
        "output": "SAMPLER"
      },
      {
        "node": "ManualSigmas_stage2",
        "params": {
          "sigmas": "0.85, 0.7250, 0.4219, 0.0"
        },
        "output": "SIGMAS"
      },
      {
        "node": "SamplerCustomAdvanced_stage2",
        "inputs": {
          "latent_image": "av_latent_stage2_input"
        },
        "output": "av_latent_stage2"
      },
      {
        "node": "LTXVSeparateAVLatent_final",
        "inputs": {
          "av_latent": "av_latent_stage2"
        },
        "output": [
          "video_latent_final",
          "audio_latent_final"
        ]
      }
    ],
    "section_F_decode_and_output": [
      {
        "node": "VAEDecodeTiled",
        "inputs": {
          "samples": "video_latent_final",
          "vae": "video_vae"
        },
        "params": {
          "tile_size": 512,
          "overlap": 64,
          "temporal_size": 2048,
          "temporal_overlap": 8
        },
        "output": "IMAGE"
      },
      {
        "node": "LTXVAudioVAEDecode",
        "inputs": {
          "samples": "audio_latent_final",
          "audio_vae": "audio_vae"
        },
        "output": "AUDIO"
      },
      {
        "node": "CreateVideo",
        "inputs": {
          "images": "IMAGE",
          "audio": "AUDIO",
          "fps": 24.0
        },
        "output": "VIDEO"
      },
      {
        "node": "SaveVideo",
        "params": {
          "filename_prefix": "Video/LTX-2/short_000010"
        }
      }
    ]
  },
  "usage_instructions": [
    "Copia el audio 000010_narration.wav a la carpeta input de ComfyUI o cárgalo con LoadAudio si tu build permite ruta directa.",
    "Arranca con el modelo Q4_K_M para estabilidad en la RTX 4070.",
    "Mantén FPS=24 en todo el workflow: conditioning, decode y create video.",
    "Haz la primera prueba con 97 frames y luego sube a 121 si va estable.",
    "Si quieres un avatar consistente, sustituye EmptyImage por una imagen vertical base del personaje."
  ]
}
